# ──────────────────────────────────────────────
# CuacaKini - Environment Configuration
# ──────────────────────────────────────────────
# Copy file ini menjadi .env.local untuk development
# atau isi di platform deployment Anda (Vercel, Railway, dsb.)

# ══════════════════════════════════════════════
# SITE SETTINGS
# ══════════════════════════════════════════════

# Nama aplikasi (tampil di header & judul browser)
NEXT_PUBLIC_SITE_NAME=CuacaKini

# Tagline aplikasi (tampil di bawah judul utama)
NEXT_PUBLIC_SITE_TAGLINE=Prakiraan Cuaca Indonesia

# Deskripsi singkat (untuk SEO meta description)
NEXT_PUBLIC_SITE_DESCRIPTION=Prakiraan cuaca terkini untuk seluruh kelurahan dan desa di Indonesia. Data cuaca 3 harian dengan pembaruan setiap 3 jam dari BMKG.

# URL produksi (digunakan untuk sitemap, OG URL, dll)
NEXT_PUBLIC_SITE_URL=https://cuacakini.id

# Bahasa konten (id = Bahasa Indonesia)
NEXT_PUBLIC_SITE_LOCALE=id_ID

# ══════════════════════════════════════════════
# SEO SETTINGS
# ══════════════════════════════════════════════

# Kata kunci SEO (dipisahkan koma)
NEXT_PUBLIC_SEO_KEYWORDS=prakiraan cuaca,cuaca Indonesia,BMKG,ramalan cuaca,suhu udara,kelembapan,kecepatan angin,cuaca hari ini,weather forecast Indonesia

# Author / publisher
NEXT_PUBLIC_SEO_AUTHOR=CuacaKini

# Twitter/X handle (dengan @)
NEXT_PUBLIC_SEO_TWITTER_HANDLE=@CuacaKini

# Google Site Verification (dari Google Search Console)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here

# ══════════════════════════════════════════════
# API SETTINGS
# ══════════════════════════════════════════════

# URL BMKG API (jangan diubah kecuali ada perubahan dari BMKG)
BMKG_API_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca

# URL Wilayah.id API (jangan diubah)
WILAYAH_API_URL=https://wilayah.id/api

# Timeout request ke API eksternal (ms) - default: 15000 = 15 detik
API_TIMEOUT_MS=15000

# Cache durasi data cuaca (detik) - default: 1800 = 30 menit
WEATHER_CACHE_SECONDS=1800

# Cache durasi data wilayah (detik) - default: 86400 = 1 hari
WILAYAH_CACHE_SECONDS=86400

# ══════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════

# Tampilkan info versi di footer (true/false)
NEXT_PUBLIC_SHOW_VERSION=false

# Mode debug (aktifkan logging tambahan di server)
# NODE_ENV sudah otomatis 'development' saat dev, jangan ubah ini
# DEBUG_MODE=false
